<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>
        <%= config.title %>
    </title>
    <%- css('css/style.css') %>
    <% if (theme.favicon.enable) { %>
        <% if (theme.favicon.icon) { %>
            <link rel="icon" href="<%= url_for(theme.favicon.icon) %>">
        <% } %>
    <% } %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@4.9.1/fonts/remixicon.css">
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.7.0/styles/atom-one-light.min.css">
</head>

<body>
    <div class="container">
        <!-- header -->
        <%- partial('_partial/header') %>

        <div class="button mobile-menu-btn" id="mobile-menu-btn">
            <span class="menu-icon ri-menu-fill"></span>
        </div>

            <div class="main-layout">
                <aside id="sidebar">
                    <%- partial('_partial/widget') %>
                </aside>
                <main id="pjax-container">
                    <%- body %>
                </main>
                <div class="sidebar-mask" id="sidebar-mask"></div>
            </div>
            <!-- footer -->
            <%- partial('_partial/footer') %>
    </div>

    <script src="/js/responsive.js"></script>
    <% if (theme.music && theme.music.enable) { %>
        <script src="/js/music.js"></script>
    <% } %>
    <script src="https://cdn.jsdelivr.net/npm/pjax/pjax.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            new Pjax({
                elements: 'a[href]:not([target]):not([data-no-pjax])',
                selectors: [
                    'title',
                    '#pjax-container',
                    '#pjax-header'
                ]
            })
        })
    </script>
    <% if (theme.giscus && theme.giscus.enable) { %>
        <script>
            window.addEventListener('DOMContentLoaded', function () {
                var container = document.getElementById('giscus-comments');
                if (!container) return;
                var script = document.createElement('script');
                script.src = 'https://giscus.app/client.js';
                script.setAttribute('data-repo', '<%= theme.giscus.repo %>');
                script.setAttribute('data-repo-id', '<%= theme.giscus.repoid %>');
                script.setAttribute('data-category', '<%= theme.giscus.category %>');
                script.setAttribute('data-category-id', '<%= theme.giscus.categoryid %>');
                script.setAttribute('data-mapping', '<%= theme.giscus.mapping || "pathname" %>');
                script.setAttribute('data-strict', '0');
                script.setAttribute('data-reactions-enabled', '1');
                script.setAttribute('data-emit-metadata', '0');
                script.setAttribute('data-input-position', 'bottom');
                script.setAttribute('data-theme', '<%= theme.giscus.theme || "preferred_color_scheme" %>');
                script.setAttribute('data-lang', 'zh-CN');
                script.crossOrigin = 'anonymous';
                script.async = true;
                container.appendChild(script);
            });
        </script>
    <% } %>
    <% if (theme.math.enable && page.mathjax) { %>
        <script>
            window.MathJax = {
                tex: {
                    inlineMath: [['$', '$'], ["\\(", "\\)"]],
                    displayMath: [ ['$$','$$'], ["\\[","\\]"] ],
                    processEscapes: true
                },
                options: {
                    skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code'] // 忽略的代码块
                }
            };
        </script>
        <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js" id="MathJax-script" async></script>
    <% } %>
</body>

</html>
